{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kin0kaze23/trace-eval/schema/trace.v1.json",
  "title": "agent-ready input format (v1) — draft; NOT yet reconciled with trace-eval v0.5.0",
  "description": "Simplified input shape agent-ready's mapper consumes today. The real trace-eval (v0.5.0) emits a different scorecard shape (total_score, dimension_scores, friction_flags). Phase 2 will add an adapter in agent-ready that reads real trace-eval JSON and produces this shape. See docs/INTEGRATION.md.",
  "type": "object",
  "required": ["schema_version", "score", "verdict", "errors"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "verdict": {
      "type": "string",
      "enum": [
        "clean",
        "minor_issues",
        "blocked_by_missing_capability",
        "blocked_by_environment",
        "blocked_by_user_input_needed",
        "unknown_failure"
      ]
    },
    "summary_human": {"type": "string"},
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern_id", "occurrences", "confidence"],
        "properties": {
          "pattern_id": {"type": "string"},
          "occurrences": {"type": "integer", "minimum": 1},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "maps_to_capability": {"type": ["string", "null"]}
        }
      }
    },
    "suggested_next_step": {
      "type": "object",
      "properties": {
        "tool": {"type": "string", "enum": ["agent-ready", "none"]},
        "command": {"type": "string"},
        "reason_human": {"type": "string"}
      }
    },
    "trace_metadata": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "duration_seconds": {"type": "number"},
        "tool_call_count": {"type": "integer"}
      }
    }
  }
}
